# Frontend env vars (Vite). Anything prefixed with VITE_ is bundled into the
# client — never put secrets here. Server-side secrets live in server/.env.

# Where the backend API lives. Same-origin if you're proxying.
VITE_API_BASE_URL="http://localhost:3000"

# Supabase project (anon key is safe to ship — it's the same key used in their
# client-side examples and is already public in your project's API URL).
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# Sentry DSN for client-side error reporting. Leave blank to disable.
VITE_SENTRY_DSN=""
VITE_SENTRY_RELEASE=""
