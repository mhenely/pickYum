# ── Database ──────────────────────────────────────────────────────────────────
#
# DATABASE_URL  → Supabase Transaction-mode pooler (port 6543).
#                 Used by the running server for all queries.
#                 Append ?pgbouncer=true so Prisma knows to skip SET commands
#                 that pgBouncer doesn't support in transaction mode.
#
# DIRECT_URL    → Supabase direct connection (port 5432).
#                 Used only by `prisma migrate` / `prisma db push`.
#                 Never reaches pgBouncer; required for DDL.
#
# Find both URLs in:
#   Supabase Dashboard → Project → Settings → Database → Connection string
#   "Transaction" tab  → copy  → change port to 6543, append ?pgbouncer=true
#   "Direct"    tab    → copy  (port 5432, no extra params)

DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── Auth ───────────────────────────────────────────────────────────────────────
# Required at startup. Generate with: openssl rand -base64 48
JWT_SECRET="replace-with-at-least-32-random-characters"

# CLIENT_URL is required in production (validated at boot). Used for CORS and
# for outbound links in verification / password-reset emails.
CLIENT_URL="http://localhost:5173"

# ── OAuth (optional — Supabase Google/Facebook) ───────────────────────────────
# If unset, /api/auth/supabase returns 503 and OAuth login is disabled.
SUPABASE_URL=""
SUPABASE_ANON_KEY=""

# Direct OAuth (optional, fallback to Passport flow). Leave blank to disable.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
API_URL="http://localhost:3000"

# ── Email (transactional) ─────────────────────────────────────────────────────
# Resend API key + verified sender address. If unset, verify-email and
# password-reset routes succeed but no email is delivered (logged + skipped).
RESEND_API_KEY=""
EMAIL_FROM="PickYum <onboarding@resend.dev>"

# ── Google Places API ─────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY="your-google-api-key"

# ── Redis (optional — required in production for shared caches & SSE pub/sub) ─
# Without REDIS_URL the server runs single-instance with in-memory fallbacks
# for sessions, places cache, and SSE broadcast.
REDIS_URL="redis://localhost:6379"

# ── Observability (optional) ──────────────────────────────────────────────────
# Sentry DSN for backend error reporting. Frontend uses VITE_SENTRY_DSN instead.
SENTRY_DSN=""
SENTRY_RELEASE=""
LOG_LEVEL=""        # debug|info|warn|error|silent — defaults match NODE_ENV

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
